{
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "editor.wordWrap": "on",
    "editor.fontFamily": "'Monaspace Argon', 'Fira Code', CodeNewRoman Nerd Font Mono, Menlo, Monaco, 'Courier New', monospace",
    "editor.fontLigatures": "'calt', 'liga', 'dlig', 'ss01', 'ss02', 'ss03', 'ss04', 'ss05', 'ss06', 'ss07', 'ss08'",
    "editor.fontSize": 13,
    "files.autoSave": "afterDelay",
    "editor.autoIndentOnPaste": true,
    "editor.linkedEditing": true,
    "editor.smoothScrolling": true,
    "editor.tabCompletion": "onlySnippets",
    "editor.cursorSmoothCaretAnimation": "explicit",
    "editor.formatOnType": true,
    "files.insertFinalNewline": true,
    "window.closeWhenEmpty": true,
    "telemetry.editStats.enabled": false,
    "telemetry.feedback.enabled": false,
    "telemetry.telemetryLevel": "off",
    "C_Cpp.autoAddFileAssociations": true,
    "C_Cpp.autocompleteAddParentheses": true,
    "C_Cpp.codeAnalysis.clangTidy.enabled": true,
    "C_Cpp.default.cppStandard": "c++26",
    "C_Cpp.default.cStandard": "c17",
    "C_Cpp.default.intelliSenseMode": "macos-clang-x64",
    "C_Cpp.experimentalFeatures": "enabled",
    "C_Cpp.clang_format_fallbackStyle": "Google",
    "C_Cpp.clang_format_style": "{ BasedOnStyle: LLVM, UseTab: Always, IndentWidth: 4, TabWidth: 4, AllowShortIfStatementsOnASingleLine: false, IndentCaseLabels: true, ColumnLimit: 0, AccessModifierOffset: -2, NamespaceIndentation: All, FixNamespaceComments: false, ContinuationIndentWidth: 4, AlignAfterOpenBracket: DontAlign }",
    "C_Cpp.vcFormat.indent.braces": true,
    "cmake.configureOnOpen": false,
    "cmake.configureOnEdit": false,
    "terminal.integrated.stickyScroll.enabled": true,
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.cursorStyle": "line",
    "terminal.integrated.defaultProfile.osx": "zsh",
    "terminal.integrated.fontLigatures.enabled": true,
    "terminal.integrated.fontFamily": "'Hack Nerd Font'",
    "terminal.integrated.fontLigatures.featureSettings": "'calt', 'liga', 'dlig', 'ss01', 'ss02', 'ss03', 'ss04', 'ss05', 'ss06', 'ss07', 'ss08'",
    "terminal.integrated.enableImages": true,
    "github.gitProtocol": "ssh",
    "protobuf.protoc.path": "/usr/local/bin/protoc",
    "protobuf.breaking.enabled": true,
    "protobuf.diagnostics.namingConventions": false,
    "terminal.integrated.defaultProfile.linux": "bash",
    "editor.minimap.autohide": "mouseover",
    "python.defaultInterpreterPath": "/Users/saugata/Desktop/Developer/PracticeProgramming/.venv/bin/python",
    "python.analysis.autoFormatStrings": true,
    "python.analysis.autoImportCompletions": true,
    "python.analysis.completeFunctionParens": true,
    "python.analysis.inlayHints.functionReturnTypes": true,
    "python.analysis.inlayHints.pytestParameters": true,
    "python.testing.pytestEnabled": true,
    "python.testing.unittestEnabled": true,
    "python.analysis.typeCheckingMode": "standard",
    "diffEditor.codeLens": true,
    "editor.acceptSuggestionOnEnter": "off",
    "workbench.enableExperiments": false,
    "workbench.list.smoothScrolling": true,
    "workbench.editor.highlightModifiedTabs": true,
    "C_Cpp.inlayHints.autoDeclarationTypes.enabled": true,
    "C_Cpp.inlayHints.autoDeclarationTypes.showOnLeft": true,
    "C_Cpp.inlayHints.parameterNames.enabled": true,
    "C_Cpp.inlayHints.referenceOperator.enabled": true,
    "C_Cpp.loggingLevel": "Debug",
    "python.analysis.languageServerMode": "full",
    "rainbow_csv.highlight_rows": true,
    "editor.inlayHints.enabled": "offUnlessPressed",
    "explorer.confirmDelete": false,
    "github.copilot.enable": {
        "*": false,
        "plaintext": false,
        "markdown": false,
        "scminput": false
    },
    "chat.viewSessions.orientation": "stacked",
    // "workbench.iconTheme": "idl-icons",
    "files.associations": {
        "*.idl": "idl"
    },
    "diffEditor.renderSideBySide": false,
    "chat.disableAIFeatures": true,
    "workbench.colorTheme": "Dark Modern"
}